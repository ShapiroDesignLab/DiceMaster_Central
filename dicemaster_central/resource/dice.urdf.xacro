<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="dice_master">
  
  <!-- Include the screen component macro -->
  <xacro:include filename="screen_component.urdf.xacro"/>
  
  <!-- Base link (center of the dice) -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.1016 0.1016 0.1016"/> <!-- 4 inches = 0.1016 meters -->
      </geometry>
      <material name="dice_body">
        <color rgba="0.2 0.2 0.2 0.8"/> <!-- Dark gray with transparency -->
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.1016 0.1016 0.1016"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- IMU link (at center of dice, aligned with base_link) -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/> <!-- IMU at center of dice -->
  </joint>
  
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.005"/> <!-- Small IMU sensor -->
      </geometry>
      <material name="imu_sensor">
        <color rgba="0.3 0.3 0.3 0.9"/> <!-- Dark gray for IMU -->
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Screen 1: Top face (+Z direction) -->
  <xacro:screen_component screen_id="1" color_r="1.0" color_g="0.0" color_b="0.0"/> <!-- Red -->
  <joint name="screen_1_joint" type="fixed">
    <parent link="base_link"/>
    <child link="screen_1_link"/>
    <origin xyz="0 0 0.0508" rpy="0 0 0"/> <!-- Half cube height up -->
  </joint>

  <!-- Screen 2: Right face (+Y direction) -->
  <xacro:screen_component screen_id="2" color_r="0.0" color_g="0.0" color_b="1.0"/> <!-- Blue -->
  <joint name="screen_2_joint" type="fixed">
    <parent link="base_link"/>
    <child link="screen_2_link"/>
    <origin xyz="0 0.0508 0" rpy="1.5708 0 3.14159"/> <!-- Rotated to face +Y -->
  </joint>

  <!-- Screen 3: Back face (+X direction) -->
  <xacro:screen_component screen_id="3" color_r="0.0" color_g="1.0" color_b="0.0"/> <!-- Green -->
  <joint name="screen_3_joint" type="fixed">
    <parent link="base_link"/>
    <child link="screen_3_link"/>
    <origin xyz="0.0508 0 0" rpy="1.5708 0 1.5708"/> <!-- Rotated to face +X -->
  </joint>

  <!-- Screen 4: Left face (-Y direction) -->
  <xacro:screen_component screen_id="4" color_r="1.0" color_g="0.0" color_b="1.0"/> <!-- Magenta -->
  <joint name="screen_4_joint" type="fixed">
    <parent link="base_link"/>
    <child link="screen_4_link"/>
    <origin xyz="0 -0.0508 0" rpy="-1.5708 0 0"/> <!-- Rotated to face -Y -->
  </joint>

  <!-- Screen 5: Front face (-X direction) -->
  <xacro:screen_component screen_id="5" color_r="1.0" color_g="1.0" color_b="0.0"/> <!-- Yellow -->
  <joint name="screen_5_joint" type="fixed">
    <parent link="base_link"/>
    <child link="screen_5_link"/>
    <origin xyz="-0.0508 0 0" rpy="1.5708 0 -1.5708"/> <!-- Rotated to face -X -->
  </joint>

  <!-- Screen 6: Bottom face (-Z direction) -->
  <xacro:screen_component screen_id="6" color_r="0.0" color_g="1.0" color_b="1.0"/> <!-- Cyan -->
  <joint name="screen_6_joint" type="fixed">
    <parent link="base_link"/>
    <child link="screen_6_link"/>
    <origin xyz="0 0 -0.0508" rpy="0 0 3.14159"/> <!-- Half cube height down, flipped -->
  </joint>

</robot>
